FROM node:20-alpine

WORKDIR /app

# Install dependencies first for layer caching
COPY package.json ./
RUN npm install

# Copy source (overridden by volume mount in docker-compose)
COPY . .

EXPOSE 3000

# Bind to 0.0.0.0 so the port is accessible from the host
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
