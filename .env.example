# ─────────────────────────────────────────────────────────────────────────────
# TalePanel — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# API — Go Backend
# ─────────────────────────────────────────────

# Server
SERVER_PORT=8080
ENV=development                         # development | production
LOG_LEVEL=info                          # debug | info | warn | error

# Database (PostgreSQL)
DATABASE_URL=postgres://talepanel:changeme@localhost:5432/talepanel?sslmode=disable

# Cache / Queue (Redis)
REDIS_URL=redis://:changeme@localhost:6379/0

# JWT — Generate with: openssl rand -hex 32
# REQUIRED in production. Min 32 characters.
JWT_SECRET=replace-with-at-least-32-char-random-secret-here
JWT_REFRESH_SECRET=replace-with-different-32-char-random-secret

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# MinIO / S3 (object storage for backups)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=talepanel-backups
MINIO_USE_SSL=false

# Daemon servers base directory — absolute path on daemon nodes where
# server data directories are created: {DAEMON_SERVERS_DIR}/{server_id}
# Must match TALEDAEMON_DATA_ROOT + /servers in daemon config.toml.
DAEMON_SERVERS_DIR=/srv/taledaemon/servers

# Email (for alerts — optional in MVP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=changeme
# SMTP_FROM=TalePanel <noreply@example.com>

# ─────────────────────────────────────────────
# Daemon — Rust Node Agent
# (these go in config.toml on each node)
# ─────────────────────────────────────────────

# TALEDAEMON_NODE_ID=generate-with-uuidgen
# TALEDAEMON_API_URL=http://localhost:8080
# TALEDAEMON_NODE_TOKEN=issued-by-api-on-node-registration
# TALEDAEMON_LISTEN_PORT=8444
# TALEDAEMON_DATA_ROOT=/srv/taledaemon
# TALEDAEMON_LOG_LEVEL=info
# TALEDAEMON_ENV=development

# ─────────────────────────────────────────────
# Web Panel — Nuxt 3
# ─────────────────────────────────────────────

NUXT_PUBLIC_API_BASE=http://localhost:8080/api/v1

# ─────────────────────────────────────────────
# Docker Compose overrides
# ─────────────────────────────────────────────

POSTGRES_USER=talepanel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=talepanel
REDIS_PASSWORD=changeme
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
