# ─────────────────────────────────────────────────────────────────────────────
# TalePanel — Panel Host Environment
# Populated by scripts/install-panel.sh.  Never commit this file.
# ─────────────────────────────────────────────────────────────────────────────

# Public domain the panel serves from (used by Caddy for Let's Encrypt and
# by the API for CORS).  Example: panel.example.com
DOMAIN=CHANGEME_GENERATED_BY_INSTALLER

# Postgres
POSTGRES_USER=talepanel
POSTGRES_DB=talepanel
POSTGRES_PASSWORD=CHANGEME_GENERATED_BY_INSTALLER

# Redis
REDIS_PASSWORD=CHANGEME_GENERATED_BY_INSTALLER

# MinIO
MINIO_ROOT_USER=talepanel
MINIO_ROOT_PASSWORD=CHANGEME_GENERATED_BY_INSTALLER

# JWT — min 32 chars, config.Load rejects the CHANGEME placeholder.
JWT_SECRET=CHANGEME_GENERATED_BY_INSTALLER
JWT_REFRESH_SECRET=CHANGEME_GENERATED_BY_INSTALLER

# TOTP encryption key — 32 bytes hex (64 hex chars) for AES-256-GCM.
TOTP_ENC_KEY=CHANGEME_GENERATED_BY_INSTALLER

# CurseForge — optional.  Leave empty to disable the mod browser.
# Obtain a key at https://console.curseforge.com and paste it raw.
CURSEFORGE_API_KEY=

# Deployment profile — seeds default module visibility in the web UI.
#   solo    — single host, no multi-node management (default)
#   hoster  — multi-tenant hosting provider; nodes + monitoring shown by default
# Operators can switch this in Settings → Modules at any time.
DEPLOYMENT_PROFILE=solo
